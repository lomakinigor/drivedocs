# drivedocs — environment variables
# Copy to .env.local and fill in your project values.
# If VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are absent,
# the app runs in localStorage-only mode (no backend, no auth required).

# ─── Supabase (frontend) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Sentry (S7) ───────────────────────────────────────────────────────────────
# Without this, the app runs fine — errors are just not sent anywhere (console only).
# Free tier: 5k events/month. https://sentry.io → Project Settings → Client Keys (DSN).
VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ─── Stripe + Edge Functions ──────────────────────────────────────────────────
# These are SERVER-SIDE only. Never add STRIPE_* to this .env.local file.
# Set them as Supabase secrets via the CLI:
#
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set STRIPE_PRICE_PRO_MONTHLY=price_...
#
# STRIPE_SECRET_KEY         — Stripe secret key (sk_test_... for test mode)
# STRIPE_WEBHOOK_SECRET     — Stripe webhook signing secret (whsec_...)
# STRIPE_PRICE_PRO_MONTHLY  — Stripe Price ID for Pro monthly plan (price_...)
#
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY are automatically
# available inside Edge Functions — do not set them manually.
#
# ─── Local webhook testing ────────────────────────────────────────────────────
# To test webhooks locally with Stripe CLI:
#
#   stripe listen --forward-to http://localhost:54321/functions/v1/stripe-webhook
#
# The Stripe CLI will print a webhook signing secret (whsec_...) — use it as
# STRIPE_WEBHOOK_SECRET when running `supabase functions serve`.
